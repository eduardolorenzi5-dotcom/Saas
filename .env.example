# Copie este arquivo para .env e preencha os valores.
# Sem DATABASE_URL o app usa SQLite local (gastos.db) — ideal para dev.

# ── Núcleo ────────────────────────────────────────────────────────────
SECRET_KEY=troque-por-uma-chave-secreta-aleatoria
# DATABASE_URL=postgresql://usuario:senha@host:5432/banco   # só em produção
APP_URL=http://localhost:8080
BASE_URL=http://localhost:8080

# ── IA ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...          # console.anthropic.com
GROQ_API_KEY=gsk_...                  # console.groq.com (transcrição de áudio)
# OPENAI_API_KEY=sk-...               # opcional, fallback do Whisper

# ── WhatsApp ──────────────────────────────────────────────────────────
# Provedor: "evolution" (padrão) ou "meta" (WhatsApp Cloud API oficial)
WPP_PROVIDER=meta

# Se WPP_PROVIDER=meta (developers.facebook.com > app > WhatsApp):
WHATSAPP_TOKEN=EAA...                 # token permanente do system user
WHATSAPP_PHONE_ID=123456789012345    # Phone number ID
WHATSAPP_VERIFY_TOKEN=um-token-que-voce-inventa   # o mesmo configurado no webhook da Meta

# Se WPP_PROVIDER=evolution:
# EVOLUTION_URL=http://localhost:8081
# EVOLUTION_KEY=sua-chave-evolution
# EVOLUTION_INSTANCE=nome-da-instancia

# Número exibido na landing/checkout (com DDI, ex: 5511999999999)
WHATSAPP_NUMBER=55...
# ADMIN_WHATSAPP=55...                # recebe avisos administrativos

# ── Pagamentos ────────────────────────────────────────────────────────
MP_ACCESS_TOKEN=APP_USR-...           # Mercado Pago > Suas integrações
# KIWIFY_CHECKOUT_URL=https://pay.kiwify.com.br/...
# KIWIFY_WEBHOOK_TOKEN=...

# ── E-mail (Brevo) ────────────────────────────────────────────────────
BREVO_API_KEY=xkeysib-...             # app.brevo.com > SMTP & API
BREVO_FROM_EMAIL=contato@controlafacilai.com.br
BREVO_FROM_NAME=Controla Fácil
BACKUP_EMAIL=eduardolorenzi5@gmail.com

# ── Google Agenda (OAuth) ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=...apps.googleusercontent.com   # console.cloud.google.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
GOOGLE_REDIRECT_URI=https://controlafacilai.com.br/auth/google/callback

# ── Admin / cron / marketing ──────────────────────────────────────────
ADMIN_KEY=senha-do-painel-admin
CRON_SECRET=token-para-rotas-de-cron
# META_PIXEL_ID=...                   # pixel + CAPI (marketing)
# META_ACCESS_TOKEN=...
# GA_MEASUREMENT_ID=G-...
# TRIAL_BANNER_URL=https://...
