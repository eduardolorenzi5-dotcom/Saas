# Copie este arquivo para .env e preencha os valores

# Chave secreta do Flask (gere uma aleatória)
SECRET_KEY=troque-por-uma-chave-secreta-aleatoria

# API do Claude (obtenha em console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Evolution API (WhatsApp)
EVOLUTION_URL=http://localhost:8080
EVOLUTION_KEY=sua-chave-evolution
EVOLUTION_INSTANCE=nome-da-sua-instancia

# Para produção, configure também:
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
